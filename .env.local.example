# ════════════════════════════════════════
# GALI MART — Environment Variables
# ════════════════════════════════════════
# Yeh file .env.local mein save karo
# KABHI bhi GitHub mein push mat karo!

# ─── RAZORPAY ───────────────────────────
# razorpay.com pe account banao → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_SECRET=your_razorpay_secret_here

# Frontend ke liye (NEXT_PUBLIC prefix zaroori hai)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─── FIREBASE ───────────────────────────
# console.firebase.google.com → Project Settings → Your apps → Web
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy_your_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── GOOGLE MAPS ────────────────────────
# console.cloud.google.com → APIs → Maps JavaScript API + Places API + Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy_your_maps_key_here
GOOGLE_MAPS_KEY=AIzaSy_your_maps_key_here   # Backend ke liye (same key)

# ════════════════════════════════════════
# SETUP STEPS (ek baar karo — free mein!)
# ════════════════════════════════════════
#
# 1. RAZORPAY (10 min):
#    → razorpay.com → Sign Up (free)
#    → Settings → API Keys → Test Keys copy karo
#    → Documents dene ke baad Live Keys milenge
#
# 2. FIREBASE (10 min):
#    → console.firebase.google.com
#    → "Add project" → Gali Mart
#    → Authentication → Phone → Enable karo
#    → Firestore Database → Create database → Start in test mode
#    → Project Settings → Add web app → Config copy karo
#
# 3. GOOGLE MAPS (10 min):
#    → console.cloud.google.com
#    → New project → Enable ye 3 APIs:
#      • Maps JavaScript API
#      • Places API
#      • Geocoding API
#    → Credentials → API Key banao
#    → $200 free credit/month milega (kaafi hai!)
#
# ════════════════════════════════════════
